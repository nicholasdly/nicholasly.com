---
import Header from '../components/Header.astro';
import "../styles/globals.css";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">

	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		
		<title>{title}</title>
		<meta name=”author” content="Nicholas Ly">
		<meta name="description" content="Nicholas Ly is a software developer based out of the greater Chicago area who builds performant web applications and open-source projects." />
		<meta name="generator" content={Astro.generator} />
		
		<script is:inline>
			if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
				document.documentElement.classList.add('dark')
		  } else {
				document.documentElement.classList.remove('dark')
		  }
		</script>

		<script
			defer
			src="https://analytics.us.umami.is/script.js"
			data-website-id="78f7a5b3-df25-4525-a087-2adf5489a4d6"
		/>
	</head>

	<body class="antialiased dark:bg-neutral-900 dark:text-white mb-40 m-6">
		<main class="flex flex-col md:max-w-2xl mx-auto">
			<Header />
			<section class="prose prose-neutral dark:prose-invert text-pretty">
				<slot />
			</section>
		</main>
	</body>

</html>
