---
interface Props {
	href: string;
}

const { href } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  class="flex items-center gap-0.5 text-black dark:text-white font-medium"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    stroke-width="1.5"
    stroke="currentColor"
    fill="none"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
    <path d="M17 7l-10 10" />
    <path d="M8 7l9 0l0 9" />
  </svg>
  <span><slot/></span>
</a>