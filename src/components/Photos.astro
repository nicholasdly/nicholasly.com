---
import { Image } from 'astro:assets';

import aidedImage from '../images/aided.jpg';
import chicagoImage from '../images/chicago.jpg';
import formalImage from '../images/formal.jpg';
import golfImage from '../images/golf.jpg';
import graduationImage from '../images/graduation.jpg';
import spartahackImage from '../images/spartahack.jpg';
---

<div class="columns-2 sm:columns-3 gap-4 my-8 not-prose">
  <div class="h-40 mb-4">
    <Image
      src={aidedImage}
      alt="A selfie I took with my undergraduate drone research team"
      class="w-full h-full object-cover rounded-lg"
      loading="eager"
    />
  </div>
  <div class="h-80 mb-4 sm:mb-0">
    <Image
      src={golfImage}
      alt="A selfie I took with my undergraduate drone research team"
      class="w-full h-full object-cover rounded-lg"
      loading="eager"
    />
  </div>
  <div class="h-40 sm:h-80 sm:mb-4">
    <Image
      src={formalImage}
      alt="A selfie I took with my undergraduate drone research team"
      class="w-full h-full object-cover rounded-lg"
      loading="eager"
    />
  </div>
  <div class="h-40 mb-4 sm:mb-0">
    <Image
      src={spartahackImage}
      alt="A selfie I took with my undergraduate drone research team"
      class="w-full h-full object-cover rounded-lg"
      loading="eager"
    />
  </div>
  <div class="h-40 mb-4">
    <Image
      src={graduationImage}
      alt="A selfie I took with my undergraduate drone research team"
      class="w-full h-full object-cover rounded-lg"
      loading="eager"
    />
  </div>
  <div class="h-80">
    <Image
      src={chicagoImage}
      alt="A selfie I took with my undergraduate drone research team"
      class="w-full h-full object-cover rounded-lg"
      loading="eager"
    />
  </div>
</div>